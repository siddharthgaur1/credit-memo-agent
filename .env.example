# Which LLM backend to use. DEFAULT AND SAFE VALUE: ollama
#   ollama  -> fully local, nothing leaves this machine. Use for real borrower files.
#   openai  -> sends document content to an external API. SYNTHETIC DATA ONLY.
LLM_BACKEND=ollama

# --- Local (default) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Demo only. Setting this key alone does NOT switch backends; you must also
# --- set LLM_BACKEND=openai explicitly. That is deliberate.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Optional OpenAI-compatible base URL (OpenRouter/Azure/etc). Empty = OpenAI.
# Note: this backend uses structured parsing; a substitute must support it. The
# zero-cost path is LLM_BACKEND=ollama above, not this one.
OPENAI_BASE_URL=

# Local storage
DATA_DIR=data/local
